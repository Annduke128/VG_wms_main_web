# ============================================
# WMS Web v2 — Environment Configuration
# Copy this to .env and adjust values as needed
# ============================================

# ---- PostgreSQL ----
POSTGRES_DSN=postgres://wms:wms_secret@localhost:5432/wms?sslmode=disable
POSTGRES_DB=wms
POSTGRES_USER=wms
POSTGRES_PASSWORD=wms_secret

# ---- Redis ----
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ---- ClickHouse (future analytics) ----
CLICKHOUSE_DSN=tcp://localhost:9000?database=wms

# ---- API Server ----
PORT=8080

# ---- Static files (production) ----
# STATIC_DIR=web/dist

# ---- Frontend (Vite) ----
# In dev mode, Vite proxies /api to localhost:8080 (see vite.config.ts)
# Only set VITE_API_URL if you need to override the proxy
# VITE_API_URL=http://localhost:8080/api
